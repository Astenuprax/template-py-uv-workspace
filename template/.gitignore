# Universal noise (base layer).
# A language stack appends its build/tooling ignores below.

# OS / editor cruft
.DS_Store
Thumbs.db
*.local

# Local environment + secrets (never commit; commit a .env.example instead)
.env
.envrc

# Scratch / local-only working space
.scratch/

# Local-only session handoffs (never shipped). The structure-lint skips git-ignored paths,
# so frontmatter-less handoffs under here do not trip the docs gate.
docs/sessions/

# --- python uv-workspace stack ---

# Byte-compiled / optimised
__pycache__/
*.py[codz]
*$py.class
*.so

# Distribution / packaging
build/
dist/
wheels/
*.egg
*.egg-info/

# Virtual environments
.venv/
venv/
env/

# Test / type / lint caches
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/

# uv.lock IS committed (reproducibility). .env is ignored; .env.example is tracked.
